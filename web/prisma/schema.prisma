generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  email          String?
  passwordHash   String
  role           String    @default("USER") // "ADMIN" | "USER"
  displayName    String?
  emailVerifiedAt DateTime?
  emailVerificationCodeHash String?
  emailVerificationExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  aiMisuseCount  Int       @default(0)
  aiBlockedUntil DateTime?
  aiBlockLevel   Int       @default(0)

  statements              Statement[]
  payslips                Payslip[]
  transactions            Transaction[]
  importJobs              ImportJob[]
  reviewedStatements      Statement[]              @relation("ReviewedStatements")
  aiBans                  AiBan[]
  aiBanPardons            AiBan[]                  @relation("BanPardon")
  aiParserReviews         AiParser[]               @relation("AiParserReviewer")
  parserTrainingAnchors   ParserTrainingAnchor[]
  notificationPreferences NotificationPreference[]
  notificationEvents      NotificationEvent[]
  recurringTransactions   RecurringTransaction[]

  @@index([email])
}

model AiBan {
  id           String    @id @default(cuid())
  userId       String
  level        Int // 1=5min, 2=1h, 3=until midnight, 4=permanent
  status       String    @default("ACTIVE") // ACTIVE | EXPIRED | PARDONED
  reason       String?
  bannedAt     DateTime  @default(now())
  expiresAt    DateTime?
  pardonedAt   DateTime?
  pardonedById String?

  user       User  @relation(fields: [userId], references: [id])
  pardonedBy User? @relation("BanPardon", fields: [pardonedById], references: [id])

  @@index([userId, status])
  @@index([status])
}

model Payslip {
  id                     String    @id @default(cuid())
  userId                 String?
  incomeTransactionId    String?   @unique
  rawFilename            String
  storedFilename         String?
  sourceHash             String
  bankName               String?
  employerName           String?
  employeeName           String?
  periodLabel            String?
  payDate                DateTime?
  netAmount              Decimal?
  grossAmount            Decimal?
  currency               String    @default("ARS")
  processingStatus       String    @default("COMPLETED") // "COMPLETED" | "REVIEW_REQUIRED" | "QUEUED" | "ANALYZING" | "FAILED" | "PRELIMINARY"
  analysisProvider       String?
  analysisModel          String?
  analysisPromptVersion  String?
  analysisConfidence     Float?
  analysisNotes          String?
  analysisStructuredJson String?
  uploadedAt             DateTime  @default(now())

  user                  User?                  @relation(fields: [userId], references: [id])
  incomeTransaction     Transaction?           @relation("PayslipIncomeTransaction", fields: [incomeTransactionId], references: [id])
  aiParsers             AiParser[]
  parserTrainingAnchors ParserTrainingAnchor[]

  @@unique([userId, sourceHash])
  @@index([userId])
  @@index([uploadedAt])
}

model Bank {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  cards Card[]
}

model Card {
  id            String   @id @default(cuid())
  bankId        String
  lastFour      String
  cardNetwork   String
  cardType      String   @default("Credit")
  holderName    String
  accountNumber String?
  createdAt     DateTime @default(now())

  bank       Bank        @relation(fields: [bankId], references: [id])
  statements Statement[]

  @@unique([bankId, lastFour])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  color     String?
  createdAt DateTime @default(now())

  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Statement {
  id                     String    @id @default(cuid())
  userId                 String?
  cardId                 String
  bankName               String
  importMethod           String    @default("NATIVE") // "NATIVE" | "AI"
  processingStatus       String    @default("COMPLETED") // "COMPLETED" | "REVIEW_REQUIRED" | "REJECTED" | "PRELIMINARY" | "QUEUED"
  parserVersion          String?
  analysisProvider       String?
  analysisModel          String?
  analysisPromptVersion  String?
  analysisConfidence     Float?
  analysisNotes          String?
  analysisStructuredJson String?
  reviewedById           String?
  reviewedAt             DateTime?
  reviewNotes            String?
  periodStart            DateTime
  periodEnd              DateTime
  dueDate                DateTime
  statementNumber        String?
  uploadedAt             DateTime  @default(now())
  rawFilename            String
  storedFilename         String?
  sourceHash             String

  user                  User?                  @relation(fields: [userId], references: [id])
  reviewedBy            User?                  @relation("ReviewedStatements", fields: [reviewedById], references: [id])
  card                  Card                   @relation(fields: [cardId], references: [id])
  balanceSummary        BalanceSummary?
  transactions          Transaction[]
  importJobs            ImportJob[]
  aiParsers             AiParser[]
  parserTrainingAnchors ParserTrainingAnchor[]

  @@unique([userId, sourceHash])
  @@index([cardId, periodEnd])
  @@index([userId])
  @@index([processingStatus])
}

model ImportJob {
  id                    String    @id @default(cuid())
  userId                String?
  statementId           String?
  sourceHash            String
  rawFilename           String
  storedFilename        String?
  status                String    @default("QUEUED") // "QUEUED" | "ANALYZING" | "COMPLETED" | "REVIEW_REQUIRED" | "FAILED"
  bankName              String?
  importMethod          String    @default("AI") // "AI"
  analysisProvider      String?
  analysisModel         String?
  analysisPromptVersion String?
  analysisConfidence    Float?
  analysisNotes         String?
  sourceTextExcerpt     String?
  aiRequestPayload      String?
  aiRawResponse         String?
  aiParsedResult        String?
  attemptCount          Int       @default(0)
  lastProcessedAt       DateTime?
  errorMessage          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user      User?      @relation(fields: [userId], references: [id])
  statement Statement? @relation(fields: [statementId], references: [id])

  @@unique([userId, sourceHash])
  @@index([userId])
  @@index([status])
}

model BalanceSummary {
  id                   String   @id @default(cuid())
  statementId          String   @unique
  currency             String   @default("ARS")
  previousBalance      Decimal  @default(0)
  previousBalanceUsd   Decimal?
  paymentsApplied      Decimal  @default(0)
  totalConsumption     Decimal  @default(0)
  commissionCuentaFull Decimal  @default(0)
  selloTax             Decimal  @default(0)
  ivaTax               Decimal  @default(0)
  iibbTax              Decimal  @default(0)
  financingInterest    Decimal  @default(0)
  currentBalance       Decimal  @default(0)
  currentBalanceUsd    Decimal?
  minimumPayment       Decimal  @default(0)
  tnaArs               Float?
  temArs               Float?
  teaArs               Float?
  tnaUsd               Float?
  temUsd               Float?
  teaUsd               Float?

  statement Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                 String    @id @default(cuid())
  statementId        String?
  userId             String?
  categoryId         String?
  date               DateTime
  merchantName       String
  normalizedMerchant String?
  voucherNumber      String?
  installmentCurrent Int?
  installmentTotal   Int?
  amountArs          Decimal
  amountUsd          Decimal?
  cardLastFour       String?
  transactionType    String    @default("DEBIT")
  source             String    @default("IMPORTED") // "IMPORTED" | "MANUAL"
  isInstallment      Boolean   @default(false)
  isSubscription     Boolean   @default(false)
  isReversal         Boolean   @default(false)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())

  statement            Statement?                       @relation(fields: [statementId], references: [id], onDelete: Cascade)
  user                 User?                            @relation(fields: [userId], references: [id])
  category             Category?                        @relation(fields: [categoryId], references: [id])
  payslip              Payslip?                         @relation("PayslipIncomeTransaction")
  recurringOccurrences RecurringTransactionOccurrence[]

  @@index([statementId])
  @@index([userId])
  @@index([date])
  @@index([categoryId])
}

model NotificationChannel {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String
  enabled    Boolean  @default(true)
  isDefault  Boolean  @default(false)
  configJson String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  templates  NotificationTemplate[]
  deliveries NotificationDelivery[]

  @@index([type])
  @@index([enabled])
}

model NotificationTemplate {
  id         String   @id @default(cuid())
  channelId  String
  eventType  String
  subject    String?
  body       String
  bodyFormat String   @default("TEXT")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, eventType])
  @@index([eventType])
}

model NotificationPreference {
  id         String   @id @default(cuid())
  userId     String
  eventType  String
  channelIds String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, eventType])
}

model NotificationEvent {
  id           String   @id @default(cuid())
  userId       String?
  eventType    String
  status       String   @default("PENDING")
  payloadJson  String
  scheduledFor DateTime @default(now())
  dedupeKey    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User?                  @relation(fields: [userId], references: [id])
  deliveries NotificationDelivery[]

  @@index([status, scheduledFor])
  @@index([eventType])
}

model NotificationDelivery {
  id                String    @id @default(cuid())
  eventId           String
  channelId         String
  status            String    @default("PENDING")
  recipient         String
  renderedSubject   String?
  renderedBody      String
  providerMessageId String?
  attemptCount      Int       @default(0)
  lastError         String?
  sentAt            DateTime?
  nextRetryAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  event   NotificationEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  channel NotificationChannel @relation(fields: [channelId], references: [id])

  @@index([status, nextRetryAt])
  @@index([eventId])
}

model RecurringTransaction {
  id                   String    @id @default(cuid())
  userId               String
  merchantName         String
  amountArs            Decimal
  amountUsd            Decimal?
  currency             String    @default("ARS")
  transactionType      String
  categoryId           String?
  frequency            String    @default("MONTHLY")
  interval             Int       @default(1)
  anchorDate           DateTime?
  dayOfMonth           Int?
  nextRunAt            DateTime
  endDate              DateTime?
  lastGeneratedAt      DateTime?
  requiresConfirmation Boolean   @default(true)
  reminderDaysBefore   Int       @default(3)
  enabled              Boolean   @default(true)
  notificationChannels String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user        User                             @relation(fields: [userId], references: [id])
  category    Category?                        @relation(fields: [categoryId], references: [id])
  occurrences RecurringTransactionOccurrence[]

  @@index([userId, enabled])
  @@index([nextRunAt])
}

model RecurringTransactionOccurrence {
  id                     String    @id @default(cuid())
  recurringTransactionId String
  dueDate                DateTime
  status                 String    @default("PENDING")
  confirmationTokenHash  String?
  expiresAt              DateTime?
  transactionId          String?
  notificationEventId    String?
  generationType         String?
  createdByMode          String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  recurringTransaction RecurringTransaction @relation(fields: [recurringTransactionId], references: [id], onDelete: Cascade)
  transaction          Transaction?         @relation(fields: [transactionId], references: [id])

  @@unique([recurringTransactionId, dueDate])
  @@index([status, dueDate])
  @@index([recurringTransactionId])
}

model AiParser {
  id              String    @id @default(cuid())
  payslipId       String?
  statementId     String?
  parserCode      String
  filePath        String
  formatSignature String
  sourceType      String // "PAYSLIP" | "STATEMENT"
  bankName        String?
  employerName    String?
  status          String    @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED
  confidence      Float?
  notes           String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())

  reviewedBy User? @relation("AiParserReviewer", fields: [reviewedById], references: [id])

  payslip               Payslip?               @relation(fields: [payslipId], references: [id])
  statement             Statement?             @relation(fields: [statementId], references: [id])
  parserTrainingAnchors ParserTrainingAnchor[]

  @@index([status])
  @@index([formatSignature])
  @@index([sourceType])
}

model ParserTrainingAnchor {
  id            String   @id @default(cuid())
  aiParserId    String?
  payslipId     String?
  statementId   String?
  sourceType    String // PAYSLIP | STATEMENT
  fieldName     String
  pageNumber    Int
  x0            Float
  top           Float
  x1            Float
  bottom        Float
  mode          String // region_exact | right_of_label | below_label | row_capture
  rawText       String?
  confirmedText String?
  labelText     String?
  trainedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  aiParser  AiParser?  @relation(fields: [aiParserId], references: [id], onDelete: Cascade)
  payslip   Payslip?   @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  statement Statement? @relation(fields: [statementId], references: [id], onDelete: Cascade)
  trainedBy User?      @relation(fields: [trainedById], references: [id])

  @@index([sourceType])
  @@index([aiParserId])
  @@index([payslipId])
  @@index([statementId])
}
